{
  "common": {
    "name": "laundrylens",
    "version": "0.2.2",
    "news": {
      "0.2.2": {
        "en": "Debug log now shows the best candidate (program + confidence) and current match threshold even when there is no official match yet",
        "de": "Debug-Log zeigt jetzt den besten Kandidaten (Programm + Konfidenz) und die aktuelle Erkennungsschwelle, auch wenn noch kein offizielles Match vorliegt"
      },
      "0.2.1": {
        "en": "Removed HA-Import feature (unused, button + backend handler)",
        "de": "HA-Import entfernt (ungenutzt, Button + Backend-Handler)"
      },
      "0.2.0": {
        "en": "Alpha release: cycle detection, self-learning program matching, admin UI with cycle graphs, Telegram notifications, full export/import",
        "de": "Alpha-Release: Zykluserkennung, selbstlernendes Programm-Matching, Admin-UI mit Zyklus-Graphen, Telegram-Benachrichtigungen, vollständiger Export/Import"
      }
    },
    "title": "LaundryLens",
    "titleLang": {
      "en": "LaundryLens",
      "de": "LaundryLens"
    },
    "desc": {
      "en": "Automatic detection and monitoring of laundry cycles via power measurement",
      "de": "Automatische Erkennung und Überwachung von Waschzyklen per Leistungsmessung"
    },
    "authors": [
      "backfisch88 <backfisch88@users.noreply.github.com>"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "icon": "icon.png",
    "extIcon": "https://raw.githubusercontent.com/backfisch88/ioBroker.laundrylens/main/admin/icon.png",
    "readme": "https://github.com/backfisch88/ioBroker.laundrylens/blob/main/README.md",
    "enabled": true,
    "loglevel": "info",
    "mode": "daemon",
    "type": "general",
    "compact": true,
    "messagebox": true,
    "materializeTab": true,
    "adminTab": {
      "singleton": true,
      "name": {
        "en": "LaundryLens",
        "de": "LaundryLens"
      },
      "fa-icon": "bath"
    },
    "adminUI": {
      "config": "json",
      "tab": "html"
    },
    "connectionType": "local",
    "dataSource": "push",
    "dependencies": [
      {
        "js-controller": ">=5.0.0"
      }
    ],
    "node": ">=18.0.0"
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected",
        "role": "indicator.connected",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "files",
      "type": "meta",
      "common": {
        "name": "LaundryLens files",
        "type": "meta.folder"
      },
      "native": {}
    }
  ],
  "native": {
    "ignoreAntiKnitter": true
  }
}
